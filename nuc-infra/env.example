# Copy to .env before running podman-compose: cp env.example .env

# GitHub user/org that owns the GHCR images
# Fix 13: replaced personal username with a placeholder
GH_USER=your-github-username

# Bearer token required by ai-wrapper (leave empty for internal-only open mode)
WRAPPER_API_KEY=change-me

# Absolute host path to the models directory (used by ai-wrapper to mount
# models into dynamically launched engine containers)
MODELS_HOST_DIR=/var/home/core/nuc-infra/data/models

# Fix 13: ALLOW_ANONYMOUS — uncomment to permit unauthenticated access to ai-wrapper.
# WARNING: only use this on a fully trusted, firewalled network.
# ALLOW_ANONYMOUS=true

# LibreChat secrets — REQUIRED, do not leave empty (empty keys mean
# credentials are stored effectively unencrypted).
CREDS_KEY=REPLACE_WITH_openssl_rand_hex_32
CREDS_IV=REPLACE_WITH_openssl_rand_hex_16
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=REPLACE_WITH_openssl_rand_hex_32
